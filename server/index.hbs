<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <script src="/main.min.js"></script>

  <link rel="stylesheet" href="/main.css" />
  <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="icon" href="/favicon.ico" type="image/x-icon" />
  <link rel="icon" href="/favicon-16x16.png" type="image/png" />
  <link rel="manifest" href="/manifest.json" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" type="image/png" />
  <title>{{title}}</title>

  <!-- Primary meta tags -->
  <meta name="title" content="{{title}}" />
  <meta name="description" content="{{description}}" />
  <meta name="robots" content="{{robots}}" />

  <!-- Canonical URL -->
  <link rel="canonical" href="https://acode.app{{canonicalPath}}" />

  <!-- Open Graph meta tags -->
  <meta property="og:title" content="{{title}}" />
  <meta property="og:description" content="{{description}}" />
  <meta property="og:image" content="https://acode.app/{{icon}}" />
  <meta property="og:image:width" content="400" />
  <meta property="og:image:height" content="200" />
  <meta property="og:image:alt" content="{{icon_alt}}" />
  <meta property="og:url" content="https://acode.app/{{ogUrl}}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="{{site_name}}" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card meta tags -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{title}}" />
  <meta name="twitter:description" content="{{description}}" />
  <meta name="twitter:image" content="https://acode.app/{{icon}}" />
  <meta name="twitter:image:alt" content="{{icon_alt}}" />

  {{#if pageSchema}}
  <!-- Structured data (JSON-LD) -->
  <script type="application/ld+json">{{{pageSchema}}}</script>
  {{/if}}
  {{#if orgSchema}}
  <script type="application/ld+json">{{{orgSchema}}}</script>
  {{/if}}

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-YX6J9WVCDP"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag('js', new Date());

    gtag('config', 'G-YX6J9WVCDP');
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5911839694379275"
    crossorigin="anonymous"></script>
</head>

<body>
  <noscript>Please enable javascript to view this page.</noscript>
  <div id="app"></div>
</body>

</html>